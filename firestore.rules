rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.adminUid == request.auth.uid;
      
      match /activities/{activityId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if request.auth != null && get(/databases/$(database)/documents/projects/$(projectId)).data.adminUid == request.auth.uid;
      }
    }
  }
}
